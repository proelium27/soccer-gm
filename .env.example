# PostHog analytics (custom gameplay events + page views).
# Create a free project at https://posthog.com, then copy your Project API key
# here (Settings > Project > Project API Key). It's a public client-side key.
# Leave unset to disable analytics entirely (e.g. local dev).
VITE_POSTHOG_KEY=

# Optional. Only set if your project is on EU cloud: https://eu.i.posthog.com
# VITE_POSTHOG_HOST=https://us.i.posthog.com
